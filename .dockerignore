.git
.gitignore
.venv
__pycache__
*.pyc
.ipynb_checkpoints
.DS_Store

# local generated artifacts
outputs/figures/*
outputs/metrics/*
outputs/predictions/*
outputs/models/*
data/raw/synthetic_telemetry.csv
