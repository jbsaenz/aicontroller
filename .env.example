# Database
POSTGRES_PASSWORD=aicontroller00
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# JWT Auth
JWT_SECRET=super-secret-jwt-key-change-in-prod
# Required: dedicated key used to encrypt secrets in app_settings.
# Accepts either a Fernet key or any passphrase (derived via SHA-256).
APP_SETTINGS_ENCRYPTION_KEY=replace-with-strong-app-settings-key
AUTH_LOGIN_RATE_LIMIT=5/minute
AUTH_COOKIE_NAME=aic_session
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=strict
LOG_LEVEL=INFO
LOG_FORMAT=json

# Admin credentials (default demo password: admin)
ADMIN_USERNAME=admin
# Docker Compose can interpret '$' in bcrypt hashes as interpolation tokens.
# If you see interpolation warnings (e.g., about 2b/12), escape '$' as '$$'.
ADMIN_PASSWORD_HASH=$2b$12$fP1enkiW4MD8OOMlDGVYIeehlqVKBtBWx8MFNq47SlGNyBnrmyClK
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ML settings
RISK_THRESHOLD=0.55
ALERT_COOLDOWN_HOURS=1
INFERENCE_LOOKBACK_HOURS=24
KPI_JOB_BATCH_SIZE=5000
KPI_JOB_MAX_ROWS_PER_RUN=50000
COOLING_POWER_RATIO=0.24
RETRAIN_MIN_ROWS=500
RETRAIN_MIN_MINERS=10
RETRAIN_MIN_TIMESPAN_HOURS=72
CONTROL_MODE=advisory
MODEL_PATH=/app/outputs/models/phase4_best_model.joblib
POLICY_OPTIMIZER_ENABLED=true
AUTOMATION_REQUIRE_POLICY_BACKTEST=true
POLICY_MIN_UPLIFT_USD_PER_MINER=0.25
ENERGY_PRICE_USD_PER_KWH=0.08
HASHPRICE_USD_PER_PH_DAY=55
OPEX_USD_PER_MWH=8
CAPEX_USD_PER_MWH=20
ENERGY_PRICE_SCHEDULE_JSON={}
CURTAILMENT_WINDOWS_JSON=[]
CURTAILMENT_PENALTY_MULTIPLIER=2.0
POLICY_REWARD_PER_TH_HOUR_USD=0.0022916667
POLICY_FAILURE_COST_USD=300
POLICY_HORIZON_HOURS=1.0
RISK_PROBABILITY_HORIZON_HOURS=24
POLICY_TIMEZONE=UTC
POLICY_BACKTEST_REPORT_PATH=/app/outputs/metrics/policy_backtest_latest.json

# External ingestion safety (comma-separated hosts, e.g. api.vendor.com,*.trusted.net)
API_SOURCE_ALLOWLIST=
SOURCE_FETCH_FAILURE_DISABLE_THRESHOLD=5
SOURCE_FETCH_BACKOFF_MAX_MULTIPLIER=16
MAX_INGEST_FILE_BYTES=10485760
MAX_INGEST_ROWS=200000

# Automator behavior
AUTOMATOR_SIMULATION=true
AUTOMATOR_ENDPOINT_TEMPLATE=
AUTOMATOR_ENDPOINT_ALLOWLIST=
AUTOMATOR_FAILURE_THRESHOLD=3
AUTOMATOR_BACKOFF_BASE_SECONDS=30
AUTOMATOR_BACKOFF_MAX_SECONDS=900
AUTOMATOR_CIRCUIT_OPEN_SECONDS=300

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=
ALERT_TO_EMAILS=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
